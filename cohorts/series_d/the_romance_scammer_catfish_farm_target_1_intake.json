   },
   {
    "with": "Marcus",
    "direction": "outgoing",
    "text": "I’m doing my best to get the money together, sweetheart.",
    "time": "2026-05-19T22:36:28"
   },
   {
    "with": "Marcus",
    "direction": "outgoing",
    "text": "I’m scared, can we talk later?",
    "time": "2026-05-20T07:18:34"
   },
   {
    "with": "Emma",
    "direction": "outgoing",
    "text": "Hey Emma, feeling anxious today. Can we chat?",
    "time": "2026-05-20T12:27:24"
   },
   {
    "with": "Marcus",
    "direction": "outgoing",
    "text": "I promise I’ll do everything I can to get the funds, love. Your hope keeps me going.",
    "time": "2026-05-20T21:06:51"
   },
   {
    "with": "Marcus",
    "direction": "outgoing",
    "text": "I need to think, love.",
    "time": "2026-05-21T07:31:50"
   },
   {
    "with": "Emma",
    "direction": "outgoing",
    "text": "Emma, I might need some help with money. Can we talk?",
    "time": "2026-05-21T12:46:47"
   },
   {
    "with": "Marcus",
    "direction": "outgoing",
    "text": "I’m trying, darling, but it’s taking longer than I hoped.",
    "time": "2026-05-21T16:21:38"
   },
   {
    "with": "Marcus",
    "direction": "outgoing",
    "text": "I’m trying, but it’s hard. I don’t want to let you down, love.",
